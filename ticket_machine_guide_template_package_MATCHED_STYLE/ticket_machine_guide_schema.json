{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ticket Machine Guide Template Data",
  "type": "object",
  "required": [
    "title",
    "steps",
    "rows"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "string"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "category",
          "buttons"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "buttons": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "footer_note": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}