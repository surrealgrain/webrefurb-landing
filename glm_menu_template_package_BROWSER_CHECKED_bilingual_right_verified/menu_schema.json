{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Restaurant English Menu Template Data",
  "type": "object",
  "required": [
    "menu_type",
    "title",
    "sections",
    "show_prices"
  ],
  "properties": {
    "menu_type": {
      "type": "string",
      "enum": [
        "food",
        "drinks",
        "combined",
        "custom"
      ]
    },
    "title": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "items"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "required": [
                    "name"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "price": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "description": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "japanese_name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "additionalProperties": false
      }
    },
    "show_prices": {
      "type": "boolean"
    },
    "footer_note": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}